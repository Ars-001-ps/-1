class account:
    def __init__(self, name, balance = 0):
        self.account_holder = name
        self.__balance = balance
        

    def deposit(self):
        try:
            amount = int(input('какую сумму вы хотите внести? ---> '))
        except:
            print('введите корректную сумму')
            return
        if amount <= 0:
            print('минимальная сумма пополнения 1 рубль!')
        else:
            self.__balance += amount
            print(f'готово! Ваш баланс: {self.__balance} рублей.')
 



    def withdraw(self):
        try:
            amount = int(input('какую сумму вы хотите снять? ---> '))
        except:
            print('введите корректную сумму')
            return
        if amount <= 0:
            print('минимальная сумма для снятия 1 рубль!')
        elif self.__balance - amount < 0:
            print('на балансе не хватает средств')
            return
        else:
            self.__balance -= amount
        print(f'готово! Остаток баланса: {self.__balance} рублей.')
        

    def get_balance(self):
        print(f'Ваш баланс: {self.__balance} рублей.')


    def __str__(self):
        return f'Владелец счёта {self.account_holder}, Баланс счёта: {self.__balance} рублей.'
    



class SavingAccount(account):
    def __init__(self, name, interest_rate, balance = 0):
        super().__init__(name, balance)
        self.interest_rate = interest_rate

    def add_interest(self):
        interest = self.balance * self.interest_rate / 100
        self.balance += interest
        print(f'На ваш баланс добавлено {interest}. Ваш счёт {self.balance} рублей.')




class BusinessAccount(account):
    def __init__(self, name, balance = 0, overdraft_limit = 10000):
        super().__init__(name, balance)
        self.OvLim = overdraft_limit

    def withdraw(self):
        try:
            amount = int(input('какую сумму вы хотите снять? ---> '))
        except:
            print('введите корректную сумму')
            return

        if amount <= 0:
            print('минимальная сумма для снятия 1 рубль!')
            return

        elif amount <= self.balance:
            self.balance -= amount
            print(f'готово! Остаток баланса: {self.balance} рублей.')

        elif amount <= self.balance + self.OvLim:
            OvBal = amount - self.balance
            self.balance = 0
            self.OvLim -= OvBal

            print(f'Готово! При снятии был использован овердрафт ({OvBal} рублей.) Остаток овердрафта {self.OvLim}.')

        else:
            total_amount = self.balance + self.OvLim
            print(f'сумма превышает овердрафт. доступная сумма для снятия с учетом овердрафта {total_amount} рублей.')
            return

            
